generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Search {
  id               String   @id @default(cuid())
  domain           String
  sector           String?
  createdAt        DateTime @default(now())
  rawResults       Json
  mentions         Json
  competitors      Json
  recommendations  Json
  visibilityScore  Int?
}