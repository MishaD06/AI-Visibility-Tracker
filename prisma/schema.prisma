generator client {
  provider = "prisma-client-js"
  // ou "prisma-client" si tu veux utiliser le nouveau générateur ESM
}

datasource db {
  provider = "sqlite"
}

model Search {
  id               String   @id @default(cuid())
  domain           String
  sector           String?
  createdAt        DateTime @default(now())
  rawResults       Json
  mentions         Json
  competitors      Json
  recommendations  Json
  visibilityScore  Int?
}